      "typeVersion": 2,
      "position": [-260, 220]
    },
    {
      "parameters": {
        "operation": "write",
        "fileName": "=/data/sites/{{$json.siteSpec.slug}}/site-spec.json",
        "dataPropertyName": "siteSpec",
        "options": {}
      },
      "id": "Write_Artifact",
      "name": "Write_Artifact",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [-20, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.GITHUB_WORKFLOW_DISPATCH_URL}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"ref\":\"main\",\"inputs\":{\"slug\":$json.siteSpec.slug}}"
      },
      "id": "Trigger_GitHub_Actions",
      "name": "Trigger_GitHub_Actions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
