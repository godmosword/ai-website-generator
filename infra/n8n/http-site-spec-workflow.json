    },
    {
      "parameters": {
        "jsCode": "const b = $json.body ?? $json;\nconst siteSpec = b.siteSpec ?? b;\nif (!siteSpec || typeof siteSpec.slug !== 'string') {\n  throw new Error('Expected JSON body: full SiteSpec or { \"siteSpec\": { ... } } with slug');\n}\nreturn [{ json: { siteSpec } }];"
      },
      "id": "Normalize_SiteSpec",
      "name": "Normalize_SiteSpec",
